package mathematics;

public class AllDevisorsOfNumber {
	
	public static void basicApproch(int n) {
		for(int i=0;i<n;i++) {
			if(n%i==0) {
				System.out.println(i);
			}
		}
	}
	
	public static void mediumApproch(int n) {
		for(int i=1;i*i<=n;i++) {
			if(n%i==0) {
				System.out.println(i);
				
				if(i!=n/i) {
					System.out.println(n/i);
				}
			}
		}
	}
	
	public static void main(String args[]) {
		basicApproch(6);
	}

}
