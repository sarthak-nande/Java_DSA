package mathematics;

import java.util.Arrays;

public class PrintPrimeFactors {
	
	public static boolean isPrime(int n) {
		if(n==1) return false;
		if(n==2 || n==3) return true;
		if(n%2==0 || n%3==0) return true;
		
		for(int i=5; i*i<=n; i=i+6) {
			if(n%i==0 || n%(i+2) == 0) return false;
		}
		
		return true;
	}
	
	public static void basicApproch(int n) {
		int keep = 1;
		for(int i=2;i<n;i++) {
			if(keep>=n) break;
			if(isPrime(i)) {
				int x = i;
				while(n%x==0) {
					keep = keep * i;
					System.out.println(i);
					x = x*i;
				}
			}
		}
	}
	
	public static void smallOptimization(int n) {
		if(n<=1) return;
		
		for(int i=2; i*i<=n; i++) {
			while(n%i==0) {
				System.out.println(i);
				n = n/i;
			}
		}
		
		if(n>1) {
			System.out.println(n);
		}
	}
	
	public static void veryHighOptimization(int n) {
		if(n<=1) return;
		while(n%2==0) {
			System.out.println(2); 
			n=n/2;
		}
		while(n%3==0) {
			System.out.println(3);
			n=n/3;
		}
		
		for(int i=5;i*i<=n;i=i+6) {
			while(n%i==0) {
				System.out.println(i);
				n=n/i;
			}
			while(n%(i+2)==0) {
				System.out.println(i+2);
				n=n/i+2;
			}
		}
		if(n>1) {
			System.out.println(n);
		}
	}
	
	public static void sieve(int n) {
        // Create a boolean array and default all values to true
        boolean[] isPrime = new boolean[n + 1];
        Arrays.fill(isPrime, true);

        for (int i = 2; i <= n; i++) {
            if (isPrime[i]) {
                System.out.print(i + " ");
                
                // Mark all multiples of i as false
                for (int j = i * i; j <= n; j = j + i) {
                    isPrime[j] = false;
                }
            }
        }
    }
	
	public static void main(String args[]) {
		int n = 34;
		
		basicApproch(n);
		System.out.println("small Optimzation");
		smallOptimization(n);
		System.out.println("Very High Optimization");
		veryHighOptimization(n);
	}

}
