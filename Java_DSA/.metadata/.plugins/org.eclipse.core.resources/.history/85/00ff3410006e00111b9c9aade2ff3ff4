package mathematics;

public class FactorialOfNumber {
	
	public static int factorialOfNumber(int num) {
		int fact = 1;
		
		for(int i=1;i<=num;i++) {
			fact = fact *i;
		}
		
		return fact;
	}
	
	public static void main(String args[]) {
		int num = 4;
		
		int factorial = factorialOfNumber(num);
		
		System.out.println("Factorial of " + num + " is " + factorial);
	}

}
